{
  "manifest_version": 3,
  "name": "Profile Autofill Assistant",
  "description": "Suggests saved profile values based on inferred form field meaning.",
  "version": "0.1.19",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Profile Autofill Assistant",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content-constants.js",
        "content/content-settings.js",
        "content/content-inference.js",
        "content/content-normalizers.js",
        "content/content-consent.js",
        "content/content-overlay.js",
        "content/content-controller.js",
        "content/content-main.js"
      ],
      "css": [
        "content.css"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true,
      "run_at": "document_idle"
    }
  ]
}


